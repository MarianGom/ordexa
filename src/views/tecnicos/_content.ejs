<section class="stack-6">
  <div class="row-between">
    <div>
      <h1 class="h1">Gestionar Técnicos</h1>
      <p class="sub">Administrá los técnicos disponibles para las tareas</p>
    </div>
    <a class="btn btn-primary" href="/tecnicos/nuevo">＋ Nuevo técnico</a>
  </div>

  <div class="card card--shadow-sm">
    <div class="card__content card__content--noPad">
      <div class="tablewrap">
        <table class="table">
          <thead><tr>
            <th>Nombre</th><th>Correo</th><th>Teléfono</th><th>Estado</th><th class="right">Acciones</th>
          </tr></thead>
          <tbody>
            <% if (!tecnicos.length) { %>
              <tr><td colspan="5" class="empty">No hay técnicos registrados.</td></tr>
            <% } %>
            <% tecnicos.forEach(tecnico => { %>
              <tr>
                <td class="strong"><%= tecnico.apellido %>, <%= tecnico.nombre %></td>
                <td><%= tecnico.correo %></td>
                <td><%= tecnico.telefono || "—" %></td>
                <td><span class="badge <%= tecnico.activo ? 'badge--st-green' : 'badge--st-red' %>"><%= tecnico.activo ? "Activo" : "Inactivo" %></span></td>
                <td class="right">
                  <a class="btn btn-outline btn-sm" href="/tecnicos/<%= tecnico.id_tecnico %>/editar">Editar</a>
                  <form method="POST" action="/tecnicos/<%= tecnico.id_tecnico %>/estado" style="display:inline"
                    onsubmit="return confirm('¿Seguro que desea <%= tecnico.activo ? 'desactivar' : 'reactivar' %> este técnico?')">
                    <button class="btn btn-outline btn-sm" type="submit"><%= tecnico.activo ? "Desactivar" : "Reactivar" %></button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
