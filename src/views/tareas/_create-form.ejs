<form class="otform" action="/ordenes/<%= num_orden %>/tareas" method="POST">
  <div class="otform__section">
    <h3 class="otform__h3">Nueva tarea</h3>

    <div class="field">
      <label class="label">Descripción <span class="req">*</span></label>
      <input class="input" name="descripcion" required minlength="3" placeholder="Ej: Diagnóstico del equipo">
    </div>

    <div class="field">
      <label class="label">Materiales</label>
      <textarea class="textarea" name="materiales" rows="3" placeholder="Ej: cable, tester..."></textarea>
    </div>

    <div class="grid-2">
      <div class="field">
        <label class="label">Tiempo (min)</label>
        <input class="input" type="number" min="0" name="tiempo_necesario" placeholder="Ej: 60">
      </div>

      <div class="field">
        <label class="label">Técnico (opcional)</label>
        <select class="select" name="id_tecnico">
          <option value="">Sin asignar</option>
          <% (tecnicos || []).forEach(t => { %>
            <option value="<%= t.id_tecnico %>"><%= t.apellido %>, <%= t.nombre %></option>
          <% }) %>
        </select>
      </div>
    </div>
  </div>

  <div class="otform__actions">
    <button class="btn btn-outline" type="button" data-close-tarea>Cancelar</button>
    <button class="btn btn-primary" type="submit">Guardar tarea</button>
  </div>
</form>