<div class="stack-6" id="otPage" data-num-orden="<%= orden.num_orden %>">

  <% const rol = Number(user?.id_rol ?? user?.rol); %>
  <% const canManage = rol === 1 || (rol === 3 && Number(orden.id_responsable) === Number(user?.id_usuario)); %>

  <div class="row-between">
    <div>
      <h1 class="h1">OT #<%= orden.num_orden %></h1>
      <p class="sub">
        Trámite: <strong><%= orden.num_tramite %></strong> ·
        Estado: <span class="badge badge--st-gray"><%= orden.estado_actual %></span>
      </p>
    </div>

    <div class="row gap-2">
      <a href="/ordenes" class="btn btn-outline">← Volver</a>

      <% if (canManage) { %>
        <a href="/ordenes/<%= orden.num_orden %>/editar" class="btn btn-primary">✏ Editar</a>
      <% } %>
    </div>
  </div>

  <!-- Datos OT -->
  <div class="card card--shadow-sm">
    <div class="card__header">
      <h3 class="card__title">Datos de la orden</h3>
    </div>

    <div class="card__content">
      <div class="grid-2">
        <div><span class="muted">Nombre trámite</span><div class="strong"><%= orden.nom_tramite %></div></div>
        <div><span class="muted">Fecha carga</span><div class="strong"><%= orden.fecha_carga %></div></div>
        <div><span class="muted">Solicitante</span><div class="strong"><%= orden.solicitante %></div></div>
        <div><span class="muted">Correo</span><div class="strong"><%= orden.correo_solicitante %></div></div>
        <div><span class="muted">Prioridad</span><div class="strong"><%= orden.prioridad %></div></div>
        <div><span class="muted">Activa</span><div class="strong"><%= orden.activa ? "Sí" : "No" %></div></div>
      </div>

      <div class="mt-4">
        <span class="muted">Descripción</span>
        <div class="box"><%= orden.descripcion || "—" %></div>
      </div>
    </div>
  </div>

  <!-- Tareas -->
  <div class="card card--shadow-sm">
    <div class="card__header row-between">
      <h3 class="card__title">Tareas</h3>

      <% if (canManage) { %>
        <button class="btn btn-primary" type="button" id="btnNuevaTarea">＋ Agregar tarea</button>
      <% } %>
    </div>

    <div class="card__content card__content--noPad">
      <div class="tablewrap">
        <table class="table">
          <thead>
            <tr>
              <th>#</th>
              <th>Descripción</th>
              <th class="hide-md">Materiales</th>
              <th>Técnico</th>
              <th class="right">Acciones</th>
            </tr>
          </thead>

          <tbody>
            <% if (tareas && tareas.length) { %>
              <% tareas.forEach(t => { %>
                <tr>
                  <td class="strong"><%= t.id_tarea %></td>
                  <td><%= t.descripcion || "-" %></td>
                  <td class="hide-md"><span class="clamp-2"><%= t.materiales || "-" %></span></td>

                  <td>
                    <% if (t.tecnico) { %>
                      <%= t.tecnico.nombre %> <%= t.tecnico.apellido %>
                    <% } else { %>
                      <span class="muted">Sin asignar</span>
                    <% } %>
                  </td>

                  <td class="right">
                    <% if (canManage) { %>
                      <button
                        class="btn btn-outline btn-sm"
                        type="button"
                        data-edit-tarea="<%= t.id_tarea %>"
                        data-num-orden="<%= orden.num_orden %>">
                        Editar
                      </button>

                      <form method="POST"
                            action="/tareas/<%= t.id_tarea %>/eliminar"
                            style="display:inline"
                            onsubmit="return confirm('¿Eliminar esta tarea?')">
                        <input type="hidden" name="num_orden" value="<%= orden.num_orden %>">
                        <button class="btn btn-outline btn-sm" type="submit">Eliminar</button>
                      </form>
                    <% } else { %>
                      —
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="5" class="empty">Todavía no hay tareas para esta OT</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Historial -->
  <div class="card card--shadow-sm">
    <div class="card__header">
      <h3 class="card__title">Historial de estados</h3>
    </div>
    <div class="card__content">
      <% if (historial && historial.length) { %>
        <ul class="timeline">
          <% historial.forEach(h => { %>
            <li class="timeline__item">
              <div class="timeline__title"><strong><%= h.estado_actual %></strong></div>
              <div class="timeline__meta muted"><%= h.fecha_cambio %> · <%= h.nota || "—" %></div>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <div class="empty">No hay historial todavía</div>
      <% } %>
    </div>
  </div>

  <!-- Archivos -->
  <div class="card card--shadow-sm">
    <div class="card__header">
      <h3 class="card__title">Archivos adjuntos</h3>
    </div>
    <div class="card__content">
      <% if (orden.archivos && orden.archivos.length) { %>
        <ul>
          <% orden.archivos.forEach(a => { %>
            <li><a href="<%= a.ruta %>" target="_blank"><%= a.nombre %></a></li>
          <% }) %>
        </ul>
      <% } else { %>
        <p class="muted">Sin adjuntos</p>
      <% } %>
    </div>
  </div>

  <!-- ===== MODAL: NUEVA TAREA ===== -->
  <div class="modal" id="modalTarea" aria-hidden="true">
    <div class="modal__backdrop" data-close-tarea></div>
    <div class="modal__panel" role="dialog" aria-modal="true">
      <button class="modal__close" type="button" data-close-tarea>✕</button>
      <h2 class="modal__title">Agregar tarea</h2>
      <p class="modal__sub">Completá los campos</p>
      <div class="modal__body" id="modalTareaBody">
        <div class="modal__loading">Cargando formulario…</div>
      </div>
    </div>
  </div>

  <!-- ===== MODAL: EDITAR TAREA ===== -->
  <div class="modal" id="modalEditTarea" aria-hidden="true">
    <div class="modal__backdrop" data-close-edittarea></div>
    <div class="modal__panel" role="dialog" aria-modal="true">
      <button class="modal__close" type="button" data-close-edittarea>✕</button>
      <h2 class="modal__title">Editar tarea</h2>
      <p class="modal__sub">Actualizá los datos</p>
      <div class="modal__body" id="modalEditTareaBody">
        <div class="modal__loading">Cargando formulario…</div>
      </div>
    </div>
  </div>

</div>

<script>
  // ===== Modal NUEVA TAREA =====
  const btnNuevaTarea = document.getElementById("btnNuevaTarea");
  const modalTarea = document.getElementById("modalTarea");
  const modalTareaBody = document.getElementById("modalTareaBody");
  const NUM_ORDEN = Number(document.getElementById("otPage")?.dataset.numOrden);

  function openModalTarea(){
    modalTarea.classList.add("is-open");
    modalTarea.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";

    fetch(`/ordenes/${NUM_ORDEN}/tareas/nueva`)
      .then(r => r.text())
      .then(html => {
        modalTareaBody.innerHTML = html;

        // Botón cancelar interno
        modalTareaBody.querySelectorAll("[data-close-tarea]").forEach(el => {
          el.addEventListener("click", closeModalTarea);
        });
      })
      .catch(() => {
        modalTareaBody.innerHTML = "<p>Error cargando formulario.</p>";
      });
  }

  function closeModalTarea(){
    modalTarea.classList.remove("is-open");
    modalTarea.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
    modalTareaBody.innerHTML = `<div class="modal__loading">Cargando formulario…</div>`;
  }

  btnNuevaTarea?.addEventListener("click", openModalTarea);
  modalTarea.querySelectorAll("[data-close-tarea]").forEach(el => el.addEventListener("click", closeModalTarea));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modalTarea.classList.contains("is-open")) closeModalTarea();
  });

  // ===== Modal EDITAR TAREA =====
  const modalEdit = document.getElementById("modalEditTarea");
  const modalEditBody = document.getElementById("modalEditTareaBody");

  function openModalEditTarea(idTarea){
    modalEdit.classList.add("is-open");
    modalEdit.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";

    fetch(`/tareas/${idTarea}/editar`)
      .then(r => r.text())
      .then(html => {
        modalEditBody.innerHTML = html;

        // Botón cancelar interno
        modalEditBody.querySelectorAll("[data-close-edittarea]").forEach(el => {
          el.addEventListener("click", closeModalEditTarea);
        });
      })
      .catch(() => {
        modalEditBody.innerHTML = "<p>Error cargando formulario.</p>";
      });
  }

  function closeModalEditTarea(){
    modalEdit.classList.remove("is-open");
    modalEdit.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
    modalEditBody.innerHTML = `<div class="modal__loading">Cargando formulario…</div>`;
  }

  document.querySelectorAll("[data-edit-tarea]").forEach(btn => {
  btn.addEventListener("click", () => {
    const raw = btn.getAttribute("data-edit-tarea");
    const id = Number(raw);

    if (!id) {
      alert("ID de tarea inválido. Revisá que t.id_tarea esté llegando.");
      return;
    }

    openModalEditTarea(id);
  });
});

  modalEdit.querySelectorAll("[data-close-edittarea]").forEach(el => el.addEventListener("click", closeModalEditTarea));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modalEdit.classList.contains("is-open")) closeModalEditTarea();
  });
</script>
