<div class="stack-6">
    <%
      const roleId = Number(user?.id_rol ?? user?.rol);
      const canCreateOrder = roleId === 1 || roleId === 2;
      const canDeleteOrder = roleId === 1;
    %>

    <!-- Header -->
    <div class="row-between">
        <div>
            <h1 class="h1">Gestionar Órdenes de Trabajo</h1>
            <p class="sub">Administra y supervisa todas las órdenes de trabajo del sistema</p>
        </div>

        <% if (canCreateOrder) { %>
        <button type="button" class="btn btn-primary" id="btnNuevaOT">
            <span class="btn__icon">＋</span>
            Nueva Orden
        </button>
        <% } %>

    </div>

    <!-- Filters -->
    <div class="card card--shadow-sm">
        <div class="card__header">
            <h3 class="card__title">Filtros de Búsqueda</h3>
        </div>

        <div class="card__content">
            <form method="GET" action="/ordenes" class="filters">

                <div class="filters__row">
                    <div class="field field--search">
                        <span class="field__icon">🔍</span>
                        <input class="input input--pl" type="text" name="q"
                            placeholder="Buscar por # Órden o Trámite..." value="<%= filters.q %>" />
                    </div>

                    <div class="field">
                        <select class="select" name="estado">
                            <option value="all" <%=filters.estado==="all" ? "selected" : "" %>>Todos los Estados
                            </option>

                            <!-- AJUSTÁ estos valores a tus ENUM exactos -->
                            <option value="En espera" <%=filters.estado==="En espera" ? "selected" : "" %>>En espera
                            </option>
                            <option value="En evaluación" <%=filters.estado==="En evaluación" ? "selected" : "" %>>En
                                evaluación</option>
                            <option value="En ejecución" <%=filters.estado==="En ejecución" ? "selected" : "" %>>En
                                ejecución</option>
                            <option value="Finalizado" <%=filters.estado==="Finalizado" ? "selected" : "" %>>Finalizado
                            </option>
                            <option value="Cancelado" <%=filters.estado==="Cancelado" ? "selected" : "" %>>Cancelado
                            </option>
                        </select>
                    </div>

                    <div class="field">
                        <select class="select" name="prioridad">
                            <option value="all" <%=filters.prioridad==="all" ? "selected" : "" %>>Todas las Prioridades
                            </option>

                            <!-- AJUSTÁ a tu ENUM exacto -->
                            <option value="Alta" <%=filters.prioridad==="Alta" ? "selected" : "" %>>Alta</option>
                            <option value="Media" <%=filters.prioridad==="Media" ? "selected" : "" %>>Media</option>
                            <option value="Baja" <%=filters.prioridad==="Baja" ? "selected" : "" %>>Baja</option>
                        </select>
                    </div>
                </div>

                <div class="filters__row">
                    <div class="field">
                        <span class="field__icon">📅</span>
                        <input class="input input--pl" type="date" name="desde" value="<%= filters.desde %>" />
                    </div>

                    <div class="field">
                        <span class="field__icon">📅</span>
                        <input class="input input--pl" type="date" name="hasta" value="<%= filters.hasta %>" />
                    </div>

                    <div class="filters__actions">
                        <a class="btn btn-outline" href="/ordenes">✕ Limpiar Filtros</a>
                        <button class="btn btn-primary" type="submit">Aplicar</button>
                    </div>
                </div>

            </form>
        </div>
    </div>

    <!-- Table -->
    <div class="card card--shadow-sm">
        <div class="card__content card__content--noPad">
            <div class="tablewrap">
                <table class="table">
                    <thead>
                        <tr>
                            <th>ID Orden</th>
                            <th>N° Trámite</th>
                            <th class="hide-md">Descripción</th>
                            <th class="hide-lg">Técnico Asignado</th>
                            <th>Prioridad</th>
                            <th>Estado</th>
                            <th class="right">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% if (ordenes && ordenes.length) { %>
                            <% ordenes.forEach(o=> { %>
                                <tr>
                                    <td class="strong">
                                        <%= o.num_orden %>
                                    </td>
                                    <td>
                                        <%= o.num_tramite %>
                                    </td>

                                    <td class="hide-md">
                                        <span class="clamp-2">
                                            <%= o.descripcion || "-" %>
                                        </span>
                                    </td>

                                    <td class="hide-lg">
                                        <% if (o.tecnicosResumen) { %>
                                            <%= o.tecnicosResumen %>
                                                <% } else { %>
                                                    <span class="muted">Sin asignar</span>
                                                    <% } %>
                                    </td>


                                    <td>
                                        <% if (o.prioridad==="Alta" ) { %>
                                            <span class="badge badge--prio-high">Alta</span>
                                            <% } else if (o.prioridad==="Media" ) { %>
                                                <span class="badge badge--prio-mid">Media</span>
                                                <% } else { %>
                                                    <span class="badge badge--prio-low">Baja</span>
                                                    <% } %>
                                    </td>

                                    <td>
                                        <% const st=o.estado_actual || "" ; %>
                                            <% if (st==="En ejecución" ) { %>
                                                <span class="badge badge--st-blue">En ejecución</span>
                                                <% } else if (st==="En evaluación" ) { %>
                                                    <span class="badge badge--st-yellow">En evaluación</span>
                                                    <% } else if (st==="En espera" ) { %>
                                                        <span class="badge badge--st-gray">En espera</span>
                                                        <% } else if (st==="Finalizado" ) { %>
                                                            <span class="badge badge--st-green">Finalizado</span>
                                                            <% } else if (st==="Cancelado" ) { %>
                                                                <span class="badge badge--st-red">Cancelado</span>
                                                                <% } else { %>
                                                                    <span class="badge badge--st-gray">
                                                                        <%= st || "-" %>
                                                                    </span>
                                                                    <% } %>
                                    </td>

                                    <td class="right">
                                        <button class="iconbtn" type="button" data-menu-btn>
                                            …
                                        </button>

                                        <div class="menu v0-menu is-hidden" data-menu>
                                            <a class="menu__item" href="/ordenes/<%= o.num_orden %>">👁 Ver Detalles</a>
                                            <% if (roleId === 1 || (roleId === 3 && Number(o.id_responsable) === Number(user.id_usuario))) { %>
                                              <a class="menu__item" href="/ordenes/<%= o.num_orden %>/editar">✏ Editar</a>
                                            <% } %>
                                            <% if (canDeleteOrder) { %>
                                            <form method="POST" action="/ordenes/<%= o.num_orden %>/eliminar"
                                                onsubmit="return confirm('¿Eliminar esta OT?')">
                                                <button class="menu__item menu__item--danger" type="submit">🗑
                                                    Eliminar</button>
                                            </form>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="7" class="empty">No hay órdenes para los filtros seleccionados
                                            </td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="pager">
                <div class="pager__meta">
                    Mostrando <%= pagination.from %> a <%= pagination.to %> de <%= pagination.total %> órdenes
                </div>

                <div class="pager__controls">
                    <% const qp=new URLSearchParams(filters); %>

                        <% qp.set("page", String(pagination.page - 1)); %>
                            <a class="btn btn-outline btn-sm <%= pagination.page === 1 ? 'is-disabled' : '' %>"
                                href="/ordenes?<%= qp.toString() %>">
                                ‹ Anterior
                            </a>

                            <div class="pager__nums">
                                <% for (let p=1; p <=pagination.totalPages; p++) { %>
                                    <% qp.set("page", String(p)); %>
                                        <a class="pagebtn <%= p === pagination.page ? 'is-active' : '' %>"
                                            href="/ordenes?<%= qp.toString() %>">
                                            <%= p %>
                                        </a>
                                        <% } %>
                            </div>

                            <% qp.set("page", String(pagination.page + 1)); %>
                                <a class="btn btn-outline btn-sm <%= pagination.page === pagination.totalPages ? 'is-disabled' : '' %>"
                                    href="/ordenes?<%= qp.toString() %>">
                                    Siguiente ›
                                </a>
                </div>
            </div>

        </div>
    </div>
    <div class="modal" id="modalOT" aria-hidden="true">
        <div class="modal__backdrop" data-close></div>
        <div class="modal__panel" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
            <button class="modal__close" type="button" data-close>✕</button>

            <h2 class="modal__title" id="modalTitle">Cargar Orden de Trabajo</h2>
            <p class="modal__sub">Complete los campos para crear una nueva orden de trabajo</p>

            <div class="modal__body" id="modalBody">
            <div class="modal__loading">Cargando formulario…</div>
            </div>
        </div>
    </div>

</div>

<script>
    // dropdown menú de acciones por fila
  const GAP = 8;

  function closeAllMenus() {
    document.querySelectorAll("[data-menu]").forEach(m => m.classList.add("is-hidden"));
  }

  function placeMenu(btn, menu) {
    const r = btn.getBoundingClientRect();

    let top = r.bottom + GAP;
    let left = r.right - menu.offsetWidth;

    if (left < GAP) left = GAP;

    // si no entra abajo, lo ponemos arriba
    if (top + menu.offsetHeight > window.innerHeight - GAP) {
      top = r.top - menu.offsetHeight - GAP;
    }

    if (top < GAP) top = GAP;

    menu.style.top = `${top}px`;
    menu.style.left = `${left}px`;
  }

  document.querySelectorAll("[data-menu-btn]").forEach((btn) => {
    const wrap = btn.parentElement;
    const menu = wrap.querySelector("[data-menu]");

    btn.addEventListener("click", (e) => {
      e.stopPropagation();

      const estabaAbierto = !menu.classList.contains("is-hidden");
      closeAllMenus();

      if (!estabaAbierto) {
        menu.classList.remove("is-hidden");
        requestAnimationFrame(() => placeMenu(btn, menu));
      }
    });
  });

  document.addEventListener("click", closeAllMenus);
  window.addEventListener("scroll", closeAllMenus, true);
  window.addEventListener("resize", closeAllMenus);

    // Formulario Modal Nueva Orden
const modal = document.getElementById("modalOT");
const body = document.getElementById("modalBody");
const btnNueva = document.getElementById("btnNuevaOT");

function initDropzone() {
  const inputArchivos = document.getElementById("archivos");
  const fileList = document.getElementById("filelist");
  const dropzone = document.getElementById("dropzone");

  if (!inputArchivos || !fileList) {
    return;
  }

  let archivosSeleccionados = [];

  inputArchivos.addEventListener("change", () => {
    const nuevosArchivos = Array.from(inputArchivos.files);

    archivosSeleccionados = [
      ...archivosSeleccionados,
      ...nuevosArchivos,
    ];

    // Evita duplicados por nombre, tamaño y última modificación
    archivosSeleccionados = archivosSeleccionados.filter(
      (archivo, indice, lista) =>
        indice ===
        lista.findIndex(
          (otro) =>
            otro.name === archivo.name &&
            otro.size === archivo.size &&
            otro.lastModified === archivo.lastModified
        )
    );

    actualizarInput();
    renderizarLista();
  });

  function renderizarLista() {
    fileList.innerHTML = "";

    if (!archivosSeleccionados.length) {
      return;
    }

    archivosSeleccionados.forEach((archivo, indice) => {
      const item = document.createElement("div");

      item.classList.add(
        "filelist__item",
        "row-between"
      );

      const info = document.createElement("div");

      const nombre = document.createElement("div");
      nombre.classList.add("strong");
      nombre.textContent = archivo.name;

      const tamaño = document.createElement("div");
      tamaño.classList.add("muted");
      tamaño.textContent = formatearTamaño(archivo.size);

      info.appendChild(nombre);
      info.appendChild(tamaño);

      const botonQuitar = document.createElement("button");

      botonQuitar.type = "button";

      botonQuitar.classList.add(
        "btn",
        "btn-outline",
        "btn-sm"
      );

      botonQuitar.textContent = "Quitar";

      botonQuitar.addEventListener("click", () => {
        archivosSeleccionados.splice(indice, 1);

        actualizarInput();
        renderizarLista();
      });

      item.appendChild(info);
      item.appendChild(botonQuitar);

      fileList.appendChild(item);
    });
  }

  function actualizarInput() {
    const dataTransfer = new DataTransfer();

    archivosSeleccionados.forEach((archivo) => {
      dataTransfer.items.add(archivo);
    });

    inputArchivos.files = dataTransfer.files;
  }

  function formatearTamaño(bytes) {
    if (bytes === 0) {
      return "0 KB";
    }

    const kilobytes = bytes / 1024;

    if (kilobytes < 1024) {
      return `${kilobytes.toFixed(1)} KB`;
    }

    const megabytes = kilobytes / 1024;

    return `${megabytes.toFixed(1)} MB`;
  }

  /*
   * Drag and drop.
   * Esto conserva la funcionalidad que ya tenía Crear OT.
   */
  if (dropzone) {
    ["dragenter", "dragover"].forEach((evento) => {
      dropzone.addEventListener(evento, (e) => {
        e.preventDefault();
        e.stopPropagation();

        dropzone.classList.add("is-dragover");
      });
    });

    ["dragleave", "drop"].forEach((evento) => {
      dropzone.addEventListener(evento, (e) => {
        e.preventDefault();
        e.stopPropagation();

        dropzone.classList.remove("is-dragover");
      });
    });

    dropzone.addEventListener("drop", (e) => {
      const nuevosArchivos = Array.from(
        e.dataTransfer.files
      );

      archivosSeleccionados = [
        ...archivosSeleccionados,
        ...nuevosArchivos,
      ];

      // Evita archivos duplicados
      archivosSeleccionados =
        archivosSeleccionados.filter(
          (archivo, indice, lista) =>
            indice ===
            lista.findIndex(
              (otro) =>
                otro.name === archivo.name &&
                otro.size === archivo.size &&
                otro.lastModified === archivo.lastModified
            )
        );

      actualizarInput();
      renderizarLista();
    });
  }
}

function openModal() {
  modal.classList.add("is-open");
  modal.setAttribute("aria-hidden", "false");
  document.body.style.overflow = "hidden";

  fetch("/ordenes/nueva")
    .then(r => r.text())
    .then(html => {
      const doc = new DOMParser().parseFromString(html, "text/html");
      const form = doc.querySelector("form");

      body.innerHTML = "";
      if (form) {
        body.appendChild(form);
        initDropzone(); // ✅ engancha eventos cuando ya existe el form
      } else {
        body.innerHTML = "<p>No se encontró el formulario.</p>";
      }
    })
    .catch(() => body.innerHTML = "<p>Error cargando formulario.</p>");
}

function closeModal() {
  modal.classList.remove("is-open");
  modal.setAttribute("aria-hidden", "true");
  document.body.style.overflow = "";
  body.innerHTML = `<div class="modal__loading">Cargando formulario…</div>`;
}

btnNueva?.addEventListener("click", openModal);

// ✅ Event delegation: funciona con botones agregados por fetch
modal.addEventListener("click", (e) => {
  if (e.target.closest("[data-close]")) closeModal();
});

document.addEventListener("keydown", (e) => {
  if (e.key === "Escape" && modal.classList.contains("is-open")) closeModal();
});

</script>
