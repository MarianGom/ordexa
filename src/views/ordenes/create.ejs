<h1>Nueva Orden de Trabajo</h1>

<% if (error) { %>
  <p style="color:red;"><%= error %></p>
<% } %>

<form action="/ordenes" method="POST">
  <div>
    <label>N° Trámite</label><br/>
    <input name="num_tramite" required value="<%= values.num_tramite || '' %>">
  </div>

  <div>
    <label>Nombre del trámite</label><br/>
    <input name="nom_tramite" required value="<%= values.nom_tramite || '' %>">
  </div>

  <div>
    <label>Solicitante</label><br/>
    <input name="solicitante" required value="<%= values.solicitante || '' %>">
  </div>

  <div>
    <label>Correo solicitante</label><br/>
    <input type="email" name="correo_solicitante" required value="<%= values.correo_solicitante || '' %>">
  </div>

  <div>
    <label>Prioridad</label><br/>
    <select name="prioridad" required>
      <option value="">-- elegir --</option>
      <option value="Alta"  <%= values.prioridad==='Alta' ? 'selected' : '' %>>Alta</option>
      <option value="Media" <%= values.prioridad==='Media' ? 'selected' : '' %>>Media</option>
      <option value="Baja"  <%= values.prioridad==='Baja' ? 'selected' : '' %>>Baja</option>
    </select>
  </div>

  <div>
    <label>Descripción</label><br/>
    <textarea name="descripcion" rows="4"><%= values.descripcion || '' %></textarea>
  </div>

  <button type="submit">Crear OT</button>
  <a href="/ordenes">Cancelar</a>
</form>
