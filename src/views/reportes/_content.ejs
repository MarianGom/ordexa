<section>
  <div class="page-header">
    <div>
      <h1>Reportes de órdenes</h1>
      <p>Consultas habilitadas según tu rol.</p>
    </div>
  </div>

  <nav style="display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:1rem">
    <% const etiquetas = { estado: "Por estado", fechas: "Por fechas", responsable: "Por responsable", prioridad: "Por prioridad", tecnico: "Por técnico" }; %>
    <% tabsPermitidos.forEach(nombre => { %>
      <a class="btn <%= tab === nombre ? 'btn-primary' : 'btn-ghost' %>" href="/reportes?tab=<%= nombre %>"><%= etiquetas[nombre] %></a>
    <% }) %>
  </nav>

  <form method="GET" action="/reportes" class="card" style="margin-bottom:1rem">
    <input type="hidden" name="tab" value="<%= tab %>">
    <div style="display:flex;gap:1rem;align-items:end;flex-wrap:wrap">
      <% if (tab === "estado") { %>
        <label>Estado
          <select name="estado">
            <option value="all">Todos</option>
            <% estados.forEach(estado => { %><option value="<%= estado %>" <%= filtros.estado === estado ? "selected" : "" %>><%= estado %></option><% }) %>
          </select>
        </label>
      <% } %>
      <% if (tab === "fechas") { %>
        <label>Desde <input type="date" name="desde" value="<%= filtros.desde %>"></label>
        <label>Hasta <input type="date" name="hasta" value="<%= filtros.hasta %>"></label>
      <% } %>
      <% if (tab === "responsable") { %>
        <label>Responsable
          <select name="id_responsable">
            <option value="all">Todos</option>
            <% responsables.forEach(persona => { %><option value="<%= persona.id_usuario %>" <%= filtros.id_responsable == persona.id_usuario ? "selected" : "" %>><%= persona.apellido %>, <%= persona.nombre %></option><% }) %>
          </select>
        </label>
      <% } %>
      <% if (tab === "prioridad") { %>
        <label>Prioridad
          <select name="prioridad">
            <option value="all">Todas</option>
            <% ["Alta", "Media", "Baja"].forEach(valor => { %><option value="<%= valor %>" <%= filtros.prioridad === valor ? "selected" : "" %>><%= valor %></option><% }) %>
          </select>
        </label>
      <% } %>
      <% if (tab === "tecnico") { %>
        <label>Técnico
          <select name="id_tecnico">
            <option value="all">Todos</option>
            <% tecnicos.forEach(persona => { %><option value="<%= persona.id_tecnico %>" <%= filtros.id_tecnico == persona.id_tecnico ? "selected" : "" %>><%= persona.apellido %>, <%= persona.nombre %></option><% }) %>
          </select>
        </label>
      <% } %>
      <button class="btn btn-primary" type="submit">Generar reporte</button>
    </div>
  </form>

  <div class="card" style="overflow:auto">
    <table class="table">
      <thead><tr>
        <% if (tab === "tecnico") { %><th>Técnico</th><% } %>
        <% if (["estado", "fechas", "responsable"].includes(tab)) { %><th>Responsable</th><% } %>
        <th>OT</th><th>Trámite</th><th>Estado</th><th>Prioridad</th>
        <% if (["prioridad", "tecnico"].includes(tab)) { %><th>Tarea</th><th>Recursos</th><% } %>
      </tr></thead>
      <tbody>
        <% if (!ordenes.length) { %><tr><td colspan="8">No se encontraron órdenes.</td></tr><% } %>
        <% ordenes.forEach(orden => { %>
          <% if (tab === "tecnico" && orden.tarea) { const tarea = orden.tarea; %>
            <tr>
              <td><%= tarea.tecnico ? `${tarea.tecnico.apellido}, ${tarea.tecnico.nombre}` : "Sin asignar" %></td>
              <td>#<%= orden.num_orden %></td><td><%= orden.num_tramite %></td><td><%= orden.estado_actual %></td><td><%= orden.prioridad %></td>
              <td><%= tarea.descripcion || "-" %></td><td><%= tarea.materiales || "-" %><%= tarea.tiempo_necesario ? ` / ${tarea.tiempo_necesario} días` : "" %></td>
            </tr>
          <% } else if (tab !== "tecnico") { %><tr>
            <% if (["estado", "fechas", "responsable"].includes(tab)) { %><td><%= orden.responsable ? `${orden.responsable.apellido}, ${orden.responsable.nombre}` : "Sin asignar" %></td><% } %>
            <td>#<%= orden.num_orden %></td><td><%= orden.num_tramite %></td><td><%= orden.estado_actual %></td><td><%= orden.prioridad %></td>
            <% if (tab === "prioridad") { %>
              <td><%= orden.tarea?.descripcion || "-" %></td>
              <td><%= orden.tarea ? [orden.tarea.materiales, orden.tarea.tiempo_necesario ? `${orden.tarea.tiempo_necesario} días` : null].filter(Boolean).join(" / ") || "-" : "-" %></td>
            <% } %>
          </tr><% } %>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
