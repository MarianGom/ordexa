<div class="stack-6">
  <div><h1 class="h1">Reportes</h1><p class="sub">Generá informes de órdenes de trabajo según distintos criterios</p></div>

  <% const labels = { estado:"Por Estado", fechas:"Por Período", responsable:"Por Responsable", prioridad:"Por Prioridad", tecnico:"Por Técnico" }; %>
  <div style="display:flex;gap:4px;border-bottom:2px solid var(--border);flex-wrap:wrap">
    <% tabsPermitidos.forEach(nombre => { %>
      <a href="/reportes?tab=<%= nombre %>" style="padding:10px 20px;font-size:13px;font-weight:600;text-decoration:none;border-radius:6px 6px 0 0;border:1px solid <%= tab === nombre ? 'var(--border)' : 'transparent' %>;border-bottom:none;margin-bottom:-2px;color:<%= tab === nombre ? 'var(--primary)' : 'var(--muted)' %>;background:<%= tab === nombre ? 'var(--card)' : 'transparent' %>"><%= labels[nombre] %></a>
    <% }) %>
  </div>

  <div class="card card--shadow-sm">
    <div class="card__header"><h3 class="card__title">OT <%= labels[tab].toLowerCase() %></h3></div>
    <div class="card__content">
      <form method="GET" action="/reportes" class="filters">
        <input type="hidden" name="tab" value="<%= tab %>">
        <div class="filters__row">
          <% if (tab === "estado") { %><div class="field"><label>Estado</label><select class="select" name="estado"><option value="">-- elegir estado --</option><option value="all" <%= filtros.estado === "all" ? "selected" : "" %>>Todos los estados</option><% estados.forEach(v => { %><option value="<%= v %>" <%= filtros.estado === v ? "selected" : "" %>><%= v %></option><% }) %></select></div><% } %>
          <% if (tab === "fechas") { %><div class="field"><label>Desde</label><input class="input-text" type="date" name="desde" value="<%= filtros.desde %>"></div><div class="field"><label>Hasta</label><input class="input-text" type="date" name="hasta" value="<%= filtros.hasta %>"></div><% } %>
          <% if (tab === "responsable") { %><div class="field"><label>Responsable</label><select class="select" name="id_responsable"><option value="">-- elegir responsable --</option><option value="all">Todos</option><% responsables.forEach(p => { %><option value="<%= p.id_usuario %>" <%= filtros.id_responsable == p.id_usuario ? "selected" : "" %>><%= p.apellido %>, <%= p.nombre %></option><% }) %></select></div><% } %>
          <% if (tab === "prioridad") { %><div class="field"><label>Prioridad</label><select class="select" name="prioridad"><option value="">-- elegir prioridad --</option><option value="all">Todas</option><% ["Alta","Media","Baja"].forEach(v => { %><option value="<%= v %>" <%= filtros.prioridad === v ? "selected" : "" %>><%= v %></option><% }) %></select></div><% } %>
          <% if (tab === "tecnico") { %><div class="field"><label>Técnico</label><select class="select" name="id_tecnico"><option value="">-- elegir técnico --</option><option value="all">Todos</option><% tecnicos.forEach(p => { %><option value="<%= p.id_tecnico %>" <%= filtros.id_tecnico == p.id_tecnico ? "selected" : "" %>><%= p.apellido %>, <%= p.nombre %></option><% }) %></select></div><% } %>
          <div class="field" style="align-self:flex-end"><button class="btn btn-primary" type="submit">Generar reporte</button></div>
        </div>
      </form>
    </div>
  </div>

  <% if (mostrarResultados) { %>
  <div class="card card--shadow-sm">
    <div class="card__header"><h3 class="card__title">Resultados <span style="font-weight:400;font-size:14px;color:var(--muted);margin-left:8px"><%= ordenes.length %> órdenes</span></h3></div>
    <div class="card__content card__content--noPad"><div class="tablewrap"><table class="table">
      <thead><tr><% if (tab === "tecnico") { %><th>Técnico</th><% } %><% if (["estado","fechas","responsable"].includes(tab)) { %><th>Responsable</th><% } %><th># Orden</th><th>N° Trámite</th><th>Estado</th><th>Prioridad</th><% if (["prioridad","tecnico"].includes(tab)) { %><th>Tarea</th><th>Recursos</th><% } %></tr></thead>
      <tbody>
        <% if (!ordenes.length) { %><tr><td colspan="8" class="empty">No se encontraron órdenes</td></tr><% } %>
        <% ordenes.forEach(ot => { %>
          <% if (tab === "tecnico") { (ot.tareas || []).forEach(t => { %><tr><td><%= t.tecnico ? `${t.tecnico.apellido}, ${t.tecnico.nombre}` : "Sin asignar" %></td><td><strong>#<%= ot.num_orden %></strong></td><td><%= ot.num_tramite %></td><td><span class="badge badge--st-gray"><%= ot.estado_actual %></span></td><td><%= ot.prioridad %></td><td><%= t.descripcion || "—" %></td><td><%= t.materiales || "—" %><%= t.tiempo_necesario ? ` / ${t.tiempo_necesario} días` : "" %></td></tr><% }); } else { %>
            <tr><% if (["estado","fechas","responsable"].includes(tab)) { %><td><%= ot.responsable ? `${ot.responsable.apellido}, ${ot.responsable.nombre}` : "Sin asignar" %></td><% } %><td><strong>#<%= ot.num_orden %></strong></td><td><%= ot.num_tramite %></td><td><span class="badge badge--st-gray"><%= ot.estado_actual %></span></td><td><%= ot.prioridad %></td><% if (tab === "prioridad") { %><td><%= (ot.tareas || []).map(t => t.descripcion).filter(Boolean).join("; ") || "—" %></td><td><%= (ot.tareas || []).map(t => t.materiales).filter(Boolean).join("; ") || "—" %></td><% } %></tr>
          <% } %>
        <% }) %>
      </tbody>
    </table></div></div>
  </div>
  <% } %>
</div>
