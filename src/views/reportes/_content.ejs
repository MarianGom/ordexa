<section>
  <div class="page-header report-heading">
    <div>
      <h1 class="h1">Reportes</h1>
      <p class="sub">Generá informes de órdenes de trabajo según distintos criterios</p>
    </div>
  </div>

  <nav class="report-tabs">
    <% const etiquetas = { estado: "Por Estado", fechas: "Por Período", responsable: "Por Responsable", prioridad: "Por Prioridad", tecnico: "Por Técnico" }; %>
    <% tabsPermitidos.forEach(nombre => { %>
      <a class="report-tab <%= tab === nombre ? 'is-active' : '' %>" href="/reportes?tab=<%= nombre %>"><%= etiquetas[nombre] %></a>
    <% }) %>
  </nav>

  <form method="GET" action="/reportes" class="card report-filter">
    <input type="hidden" name="tab" value="<%= tab %>">
    <h2><%= tab === "fechas" ? "OT por período" : `OT ${etiquetas[tab]?.toLowerCase() || ""}` %></h2>
    <div class="report-filter__fields">
      <% if (tab === "estado") { %>
        <label><span>Estado</span>
          <select class="select" name="estado">
            <option value="all">Todos</option>
            <% estados.forEach(estado => { %><option value="<%= estado %>" <%= filtros.estado === estado ? "selected" : "" %>><%= estado %></option><% }) %>
          </select>
        </label>
      <% } %>
      <% if (tab === "fechas") { %>
        <label><span>Desde</span><input class="input" type="date" name="desde" value="<%= filtros.desde %>"></label>
        <label><span>Hasta</span><input class="input" type="date" name="hasta" value="<%= filtros.hasta %>"></label>
      <% } %>
      <% if (tab === "responsable") { %>
        <label><span>Responsable</span>
          <select class="select" name="id_responsable">
            <option value="all">Todos</option>
            <% responsables.forEach(persona => { %><option value="<%= persona.id_usuario %>" <%= filtros.id_responsable == persona.id_usuario ? "selected" : "" %>><%= persona.apellido %>, <%= persona.nombre %></option><% }) %>
          </select>
        </label>
      <% } %>
      <% if (tab === "prioridad") { %>
        <label><span>Prioridad</span>
          <select class="select" name="prioridad">
            <option value="all">Todas</option>
            <% ["Alta", "Media", "Baja"].forEach(valor => { %><option value="<%= valor %>" <%= filtros.prioridad === valor ? "selected" : "" %>><%= valor %></option><% }) %>
          </select>
        </label>
      <% } %>
      <% if (tab === "tecnico") { %>
        <label><span>Técnico</span>
          <select class="select" name="id_tecnico">
            <option value="all">Todos</option>
            <% tecnicos.forEach(persona => { %><option value="<%= persona.id_tecnico %>" <%= filtros.id_tecnico == persona.id_tecnico ? "selected" : "" %>><%= persona.apellido %>, <%= persona.nombre %></option><% }) %>
          </select>
        </label>
      <% } %>
      <button class="btn btn-primary" type="submit">Generar reporte</button>
    </div>
  </form>

  <div class="card report-results">
    <table class="table">
      <thead>
        <tr>
          <% if (tab === "estado") { %>
            <th>Estado</th><th>Responsable</th><th>OT</th><th>Trámite</th><th>Descripción</th>
          <% } else if (tab === "fechas") { %>
            <th>Fecha</th><th>Responsable</th><th>OT</th><th>Trámite</th><th>Estado</th><th>Descripción</th>
          <% } else if (tab === "responsable") { %>
            <th>Responsable</th><th>OT</th><th>Descripción</th>
          <% } else if (tab === "prioridad") { %>
            <th>Prioridad</th><th>OT</th><th>Trámite</th><th>Descripción</th><th>Técnico</th><th>Recursos</th>
          <% } else if (tab === "tecnico") { %>
            <th>Técnico</th><th>OT</th><th>Descripción</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% if (!ordenes.length) { %><tr><td colspan="6">No se encontraron órdenes.</td></tr><% } %>
        <% ordenes.forEach(orden => { %>
          <% const responsable = orden.responsable ? `${orden.responsable.apellido}, ${orden.responsable.nombre}` : "Sin asignar"; %>
          <% const tecnico = orden.tarea?.tecnico ? `${orden.tarea.tecnico.apellido}, ${orden.tarea.tecnico.nombre}` : "Sin asignar"; %>
          <% const recursos = orden.tarea ? [orden.tarea.materiales, orden.tarea.tiempo_necesario ? `${orden.tarea.tiempo_necesario} días` : null].filter(Boolean).join(" / ") || "-" : "-"; %>
          <tr>
            <% if (tab === "estado") { %>
              <td><%= orden.estado_actual %></td><td><%= responsable %></td><td>#<%= orden.num_orden %></td><td><%= orden.num_tramite %></td><td><%= orden.descripcion || "-" %></td>
            <% } else if (tab === "fechas") { %>
              <td><%= orden.fecha_carga %></td><td><%= responsable %></td><td>#<%= orden.num_orden %></td><td><%= orden.num_tramite %></td><td><%= orden.estado_actual %></td><td><%= orden.descripcion || "-" %></td>
            <% } else if (tab === "responsable") { %>
              <td><%= responsable %></td><td>#<%= orden.num_orden %></td><td><%= orden.descripcion || "-" %></td>
            <% } else if (tab === "prioridad") { %>
              <td><%= orden.prioridad %></td><td>#<%= orden.num_orden %></td><td><%= orden.num_tramite %></td><td><%= orden.descripcion || "-" %></td><td><%= tecnico %></td><td><%= recursos %></td>
            <% } else if (tab === "tecnico") { %>
              <td><%= tecnico %></td><td>#<%= orden.num_orden %></td><td><%= orden.descripcion || "-" %></td>
            <% } %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
