<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || "ORDEXA" %></title>

  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/app.css">
</head>

<body>

<div class="layout">

  <!-- ========== SIDEBAR DESKTOP ========== -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>
  <aside class="sidebar">

      <div class="sidebar__brand">
        <div class="brand__logo">
          <!-- hex simple -->
          <img src="/img/logo.png" width="22" height="22" alt="logo">
        </div>
        <span class="brand__title">ORDEXA</span>
      </div>
      <nav class="sidebar__nav">

    <a href="/dashboard"
      class="navlink <%= currentPath === '/dashboard' ? 'is-active' : '' %>">
      <img src="/img/app.png" class="navlink__icon" />
      Dashboard
    </a>
<a href="/ordenes"
      class="navlink <%= currentPath === '/ordenes' ? 'is-active' : '' %>">
      <img src="/img/orden.png" class="navlink__icon" />
      Gestionar OT
    </a>

      <a href="/reportes"
      class="navlink <%= currentPath === '/reportes' ? 'is-active' : '' %>">
      <img src="/img/estadisticas.png" class="navlink__icon" />
      Reportes
    </a>
  <% if (Number(user?.id_rol ?? user?.rol) === 1) { %>
  <a
    href="/usuarios"
    class="navlink <%= currentPath === '/usuarios' ? 'is-active' : '' %>"
  >
  <img src="/img/team.png" class="navlink__icon" />
    Gestionar Usuarios
  </a>
<% } %>
    

    <% if ([1, 3].includes(Number(user?.id_rol ?? user?.rol))) { %>
    <a href="/tecnicos"
      class="navlink <%= currentPath === '/tecnicos' ? 'is-active' : '' %>">
      <img src="/img/team.png" class="navlink__icon" />
      Gestionar Técnicos
    </a>
    <% } %>

  

    <a href="/perfil"
     class="navlink <%= currentPath === '/perfil' ? 'is-active' : '' %>">
    <img src="/img/usuario.png" class="navlink__icon" />
    Perfil
    </a>
    </nav>
    <div class="sidebar__footer">
      <a href="/logout" data-confirm-logout class="btn btn-ghost" style="width:100%; justify-content:flex-start; gap:.75rem; color:var(--destructive)">
        <img src="/img/salida.png" class="navlink__icon" />
        Cerrar Sesión
      </a>
    </div>

  </aside>

  <!-- ========== MAIN ========== -->
  <div class="main">

    <!-- ===== Top Header ===== -->
    <header class="topbar">
      <div class="topbar__left">
        <button class="hamburger" id="btnSidebar" aria-expanded="false">
          <span class="hamburger__bars">☰</span>
          <span class="hamburger__close">✕</span>
        </button>

        <div class="topbar__date">
        <%= new Date().toLocaleDateString("es-AR", {
          weekday: "long",
          year: "numeric",
          month: "long",
          day: "numeric"
        }) %>
      </div>
    </div>

      <!-- User dropdown (JS simple) -->
      <div style="position:relative">

        <button id="btnUserMenu" class="btn btn-ghost userbox" type="button">

          <div class="avatar">
            <%= (user?.nombre?.[0] || "U") + (user?.apellido?.[0] || "") %>
          </div>

          <div class="userbox__meta">
            <div class="userbox__name">
              <%= user ? `${user.nombre} ${user.apellido}` : "Usuario" %>
            </div>
            <div class="userbox__email">
              <%= user?.correo || "" %>
            </div>
          </div>

          <span class="userbox__chev">▾</span>
        </button>

        <div id="userMenu"
             style="
               position:absolute;
               right:0;
               top:110%;
               width:220px;
               background:#ffff;
               border:1px solid #dce2e7;
               border-radius:4%;
               box-shadow:0 10px 24px rgba(15,23,42,.12);
               display:none;
               z-index:20;
             ">

          <div style="padding:1rem .75rem; font-size:.85rem;font-weight: 600">
            Mi Cuenta
          </div>

          <a href="/perfil" class="navlink" style="border-radius:0; font-weight: 300;
               border:1px solid #dce2e7;">
            <img src="/img/person.png" class="navlink__icon" /> Perfil
          </a>

          <a href="/logout" data-confirm-logout class="navlink_close" style="border-radius:0; border:1px solid #dce2e7; font-weight: 300">
            <img src="/img/salida.png" class="navlink__icon" />Cerrar Sesión
          </a>

        </div>

      </div>

    </header>


    <!-- ===== Page Content ===== -->
    <main class="page">
      <% if (flash) { %>
        <div class="alert <%= flash.type === 'success' ? 'alert--success' : (flash.type === 'warning' ? 'alert--warning' : 'alert--error') %>" role="status">
          <%= flash.message %>
        </div>
      <% } %>
      <%- include("../" + contentView) %>
    </main>

  </div>

</div>
<script>
  window.initVerificacionTramite = function(root = document) {
    const input = root.querySelector("#num_tramite");
    if (!input || input.dataset.verificacionActiva === "true") return;
    const status = root.querySelector("#tramite-status");
    const submit = root.querySelector("#btnGuardarOrden");
    const form = input.form;
    let timer;
    let ultimaConsulta = 0;
    let tramiteDuplicado = false;
    input.dataset.verificacionActiva = "true";

    const mostrar = (mensaje, tipo = "") => {
      status.textContent = mensaje;
      status.className = `field-status ${tipo ? `field-status--${tipo}` : ""}`;
      input.classList.toggle("input--error", tipo === "error");
      input.classList.toggle("input--success", tipo === "success");
    };
    const verificar = async () => {
      const numero = input.value.trim();
      const consulta = ++ultimaConsulta;
      tramiteDuplicado = false;
      submit.disabled = false;
      if (!numero) return mostrar("");
      mostrar("Verificando número de trámite…");
      try {
        const response = await fetch(`/api/ordenes/verificar-tramite?num_tramite=${encodeURIComponent(numero)}`);
        if (!response.ok) throw new Error("No se pudo verificar");
        const resultado = await response.json();
        if (consulta !== ultimaConsulta) return;
        tramiteDuplicado = resultado.existe;
        submit.disabled = tramiteDuplicado;
        mostrar(
          tramiteDuplicado
            ? `Este trámite ya está registrado en la OT #${resultado.num_orden}.`
            : "Número de trámite disponible.",
          tramiteDuplicado ? "error" : "success",
        );
      } catch {
        if (consulta !== ultimaConsulta) return;
        mostrar("No se pudo verificar ahora; se comprobará al guardar.", "warning");
      }
    };
    input.addEventListener("input", () => {
      clearTimeout(timer);
      mostrar("");
      tramiteDuplicado = false;
      submit.disabled = false;
      timer = setTimeout(verificar, 500);
    });
    input.addEventListener("blur", () => {
      clearTimeout(timer);
      verificar();
    });
    form.addEventListener("submit", (event) => {
      if (tramiteDuplicado) {
        event.preventDefault();
        input.focus();
      }
    });
  };
  window.initVerificacionTramite(document);

  document.querySelectorAll("[data-confirm-logout]").forEach((link) => {
    link.addEventListener("click", (event) => {
      if (!window.confirm("¿Está seguro de que desea cerrar sesión?")) {
        event.preventDefault();
      }
    });
  });

  const btn = document.getElementById("btnUserMenu");
  const menu = document.getElementById("userMenu");

  if (btn && menu) {
    btn.addEventListener("click", () => {
      menu.style.display = menu.style.display === "block" ? "none" : "block";
    });

    document.addEventListener("click", (e) => {
      if (!btn.contains(e.target) && !menu.contains(e.target)) {
        menu.style.display = "none";
      }
    });
  }

  const btnSidebar = document.getElementById("btnSidebar");
  const sidebar = document.querySelector(".sidebar");
  const overlay = document.getElementById("sidebarOverlay");

  function openSidebar(){
    sidebar.classList.add("is-open");
    overlay.classList.add("is-open");

    // 👇 ESTO ES LO QUE FALTABA
    btnSidebar.classList.add("is-open");
    btnSidebar.setAttribute("aria-expanded", "true");

    document.body.style.overflow = "hidden";
  }

  function closeSidebar(){
    sidebar.classList.remove("is-open");
    overlay.classList.remove("is-open");

    // 👇 ESTO ES LO QUE FALTABA
    btnSidebar.classList.remove("is-open");
    btnSidebar.setAttribute("aria-expanded", "false");

    document.body.style.overflow = "";
  }

  // Toggle (abre y cierra con el mismo botón)
  btnSidebar?.addEventListener("click", () => {
    const abierto = sidebar.classList.contains("is-open");
    if (abierto) closeSidebar();
    else openSidebar();
  });

  overlay?.addEventListener("click", closeSidebar);

  // cerrar al tocar un link
  document.querySelectorAll(".sidebar a").forEach(a=>{
    a.addEventListener("click", closeSidebar);
  });

  // cerrar con ESC
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && sidebar.classList.contains("is-open")) closeSidebar();
  });
</script>

</body>
</html>
