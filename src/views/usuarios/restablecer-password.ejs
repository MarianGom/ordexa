<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="stylesheet" href="/css/login.css"><title>ORDEXA | Nueva contraseña</title>
</head>
<body><main class="login">
  <section class="login__brand"><div class="brand">
    <img src="/img/logo_nombre.png" alt="ORDEXA" class="brand__logo">
    <p class="brand__subtitle">Sistema de Gestión de Órdenes de Trabajo<br>Universitario</p>
    <p class="brand__footer">Facultad de Ciencias Exactas y Tecnologías</p>
  </div></section>
  <section class="login__form"><div class="card">
    <header class="card__header"><h1 class="card__title"><%= success ? "Contraseña actualizada" : "Crear nueva contraseña" %></h1><p class="card__desc"><%= success ? "Ya podés ingresar con tu nueva contraseña." : "Usá al menos 8 caracteres." %></p></header>
    <% if (error) { %><div class="alert"><%= error %></div><% } %>
    <% if (success) { %>
      <a class="btn" href="/login" style="text-decoration:none;text-align:center">Ir al inicio de sesión</a>
    <% } else if (valid) { %>
      <form action="/restablecer-password/<%= encodeURIComponent(token) %>" method="POST" class="form">
        <div class="field"><label for="password">Nueva contraseña</label><div class="input"><span class="input__icon">🔒</span><input id="password" type="password" name="password" minlength="8" required autocomplete="new-password"></div></div>
        <div class="field"><label for="confirmation">Repetir contraseña</label><div class="input"><span class="input__icon">🔒</span><input id="confirmation" type="password" name="password_confirmation" minlength="8" required autocomplete="new-password"></div></div>
        <button class="btn" type="submit">Guardar contraseña</button>
      </form>
    <% } else { %>
      <a class="btn" href="/recuperar-password" style="text-decoration:none;text-align:center">Solicitar otro enlace</a>
    <% } %>
    <div class="card__bottom"><a class="link" href="/login">← Volver al inicio de sesión</a></div>
  </div></section>
</main></body></html>
