<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <link rel="stylesheet" href="/css/login.css">
  <title>ORDEXA | Login</title>
</head>
<body>
  <main class="login">
    <!-- Panel izquierdo -->
    <section class="login__brand">
      <div class="brand">        
          <img src="/img/logo_nombre.png" alt="ORDEXA" class="brand__logo">
        <!--<h1 class="brand__title">ORDEXA</h1>-->
        <p class="brand__subtitle">Sistema de Gestión de Órdenes de Trabajo<br/>Universitario</p>
        <p class="brand__footer">Facultad de Ciencias Exactas y Tecnologías</p>
      </div>
    </section>

    <!-- Panel derecho -->
    <section class="login__form">
      <div class="card">
        <header class="card__header">
          <h2 class="card__title">Iniciar Sesión</h2>
          
          <p class="card__desc">Ingrese sus credenciales para acceder al sistema</p>
        </header>

        <% if (error) { %>
          <div class="alert"><%= error %></div>
        <% } %>

        <form action="/login" method="POST" class="form">
          <div class="field">
            <label for="correo">Correo Electrónico</label>
            <div class="input">
              <span class="input__icon" aria-hidden="true">✉️</span>
              <input id="correo" type="email" name="correo" placeholder="usuario@ejemplo.com" required>
            </div>
          </div>

          <div class="field">
            <label for="password">Contraseña</label>
            <div class="input">
              <span class="input__icon" aria-hidden="true">🔒</span>
              <input id="password" type="password" name="password" placeholder="••••••••" required>
              <!-- (opcional) toggle con JS -->
            </div>
          </div>

          <button class="btn" type="submit">Iniciar Sesión</button>
        </form>

        <div class="card__bottom">
          <a class="link" href="#">¿Olvidaste tu contraseña?</a>
        </div>
      </div>

      <footer class="legal">© 2025 Facultad de Ciencias Exactas y Tecnologías</footer>
    </section>
  </main>
</body>
</html>
