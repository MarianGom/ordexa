<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="stylesheet" href="/css/login.css"><title>ORDEXA | Recuperar contraseña</title>
</head>
<body><main class="login">
  <section class="login__brand"><div class="brand">
    <img src="/img/logo_nombre.png" alt="ORDEXA" class="brand__logo">
    <p class="brand__subtitle">Sistema de Gestión de Órdenes de Trabajo<br>Universitario</p>
    <p class="brand__footer">Facultad de Ciencias Exactas y Tecnologías</p>
  </div></section>
  <section class="login__form"><div class="card">
    <header class="card__header"><h1 class="card__title">Recuperar contraseña</h1><p class="card__desc">Te enviaremos un enlace con vigencia de 30 minutos.</p></header>
    <% if (error) { %><div class="alert"><%= error %></div><% } %>
    <% if (message) { %><div class="alert" style="background:#ecfdf5;color:#166534;border-color:#bbf7d0"><%= message %></div><% } %>
    <form action="/recuperar-password" method="POST" class="form">
      <div class="field"><label for="correo">Correo electrónico</label><div class="input"><span class="input__icon">✉️</span><input id="correo" type="email" name="correo" required autocomplete="email"></div></div>
      <button class="btn" type="submit">Enviar enlace</button>
    </form>
    <div class="card__bottom"><a class="link" href="/login">← Volver al inicio de sesión</a></div>
  </div></section>
</main></body></html>
