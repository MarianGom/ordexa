<section class="stack-6">
  <div class="row-between">
    <div>
      <h1 class="h1">Nuevo Usuario</h1>
      <p class="sub">Completá la información para registrar un nuevo usuario</p>
    </div>
    <a href="/usuarios" class="btn btn-outline">← Volver</a>
  </div>

  <% if (error) { %>
    <div class="alert alert--error"><%= error %></div>
  <% } %>

  <form action="/usuarios" method="POST" class="card user-form">
    <div class="card__header"><h2 class="card__title">Información del usuario</h2></div>
    <div class="card__content">
      <fieldset class="form-section">
        <legend>Identificación</legend>
        <div class="form-grid">
          <label class="field"><span>CUIL *</span>
            <input class="input" type="text" name="cuil" inputmode="numeric" maxlength="11"
              placeholder="20123456789" value="<%= values.cuil || '' %>" required>
          </label>
          <label class="field"><span>Correo electrónico *</span>
            <input class="input" type="email" name="correo" placeholder="usuario@ejemplo.com"
              value="<%= values.correo || '' %>" required>
          </label>
        </div>
      </fieldset>

      <fieldset class="form-section">
        <legend>Datos personales</legend>
        <div class="form-grid">
          <label class="field"><span>Nombre *</span>
            <input class="input" type="text" name="nombre" value="<%= values.nombre || '' %>" required>
          </label>
          <label class="field"><span>Apellido *</span>
            <input class="input" type="text" name="apellido" value="<%= values.apellido || '' %>" required>
          </label>
        </div>
      </fieldset>

      <fieldset class="form-section">
        <legend>Contacto</legend>
        <div class="form-grid">
          <label class="field"><span>Teléfono</span>
            <input class="input" type="text" name="telefono" inputmode="numeric"
              placeholder="Ej: 3814123456" value="<%= values.telefono || '' %>">
          </label>
          <label class="field"><span>Domicilio</span>
            <input class="input" type="text" name="domicilio" value="<%= values.domicilio || '' %>">
          </label>
        </div>
      </fieldset>

      <fieldset class="form-section">
        <legend>Información adicional</legend>
        <label class="field"><span>Observaciones</span>
          <textarea class="input" rows="3" name="observaciones"><%= values.observaciones || '' %></textarea>
        </label>
      </fieldset>

      <fieldset class="form-section">
        <legend>Acceso</legend>
        <div class="form-grid">
          <label class="field"><span>Rol *</span>
            <select class="select" name="id_rol" required>
              <option value="">Seleccionar rol</option>
              <% roles.forEach(rol => { %>
                <option value="<%= rol.id_rol %>" <%= String(values.id_rol || '') === String(rol.id_rol) ? 'selected' : '' %>>
                  <%= rol.nombre %>
                </option>
              <% }) %>
            </select>
          </label>
          <label class="field"><span>Contraseña *</span>
            <input class="input" type="password" name="password" minlength="8"
              placeholder="Mínimo 8 caracteres" required autocomplete="new-password">
          </label>
        </div>
      </fieldset>
    </div>
    <div class="form-actions">
      <a href="/usuarios" class="btn btn-outline">Cancelar</a>
      <button type="submit" class="btn btn-primary">Guardar usuario</button>
    </div>
  </form>
</section>
