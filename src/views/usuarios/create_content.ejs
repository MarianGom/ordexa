<div class="stack-6">

    <div class="row-between">
        <div>
            <h1 class="h1">Nuevo Usuario</h1>
            <p class="sub">
                Complete la información para registrar un nuevo usuario.
            </p>
        </div>

        <a href="/usuarios" class="btn btn-outline">
            ← Volver
        </a>
    </div>

    <% if (error) { %>

        <div class="card">
            <div class="card__content">
                <p style="color:#dc2626;font-weight:600;">
                    <%= error %>
                </p>
            </div>
        </div>

    <% } %>

    <div class="card card--shadow-sm">

        <div class="card__header">
            <h3 class="card__title">
                Información del Usuario
            </h3>
        </div>

        <div class="card__content">

            <form action="/usuarios" method="POST">

                <div class="filters">

                    <div class="filters__row">

                        <div class="field">
                            <label>CUIL *</label>
                            <input
                                class="input"
                                type="text"
                                name="cuil"
                                required
                                value="<%= values.cuil || '' %>">
                        </div>

                        <div class="field">
                            <label>Correo *</label>
                            <input
                                class="input"
                                type="email"
                                name="correo"
                                required
                                value="<%= values.correo || '' %>">
                        </div>

                    </div>

                    <div class="filters__row">

                        <div class="field">
                            <label>Nombre *</label>
                            <input
                                class="input"
                                type="text"
                                name="nombre"
                                required
                                value="<%= values.nombre || '' %>">
                        </div>

                        <div class="field">
                            <label>Apellido *</label>
                            <input
                                class="input"
                                type="text"
                                name="apellido"
                                required
                                value="<%= values.apellido || '' %>">
                        </div>

                    </div>

                    <div class="filters__row">

                        <div class="field">
                            <label>Teléfono</label>
                            <input
                                class="input"
                                type="text"
                                name="telefono"
                                value="<%= values.telefono || '' %>">
                        </div>

                        <div class="field">
                            <label>Domicilio</label>
                            <input
                                class="input"
                                type="text"
                                name="domicilio"
                                value="<%= values.domicilio || '' %>">
                        </div>

                    </div>

                    <div class="filters__row">

                        <div class="field" style="width:100%">
                            <label>Observaciones</label>

                            <textarea
                                class="input"
                                rows="4"
                                name="observaciones"><%= values.observaciones || '' %></textarea>

                        </div>

                    </div>

                    <% if (user && user.id_rol === 1) { %>

                    <div class="filters__row">

                        <div class="field">

                            <label>Rol</label>

                            <select
                                class="select"
                                name="id_rol">

                                <% roles.forEach(rol => { %>

                                    <option
                                        value="<%= rol.id_rol %>"
                                        <%= values.id_rol == rol.id_rol ? "selected" : "" %>>

                                        <%= rol.nombre %>

                                    </option>

                                <% }) %>

                            </select>

                        </div>

                        <div class="field">

                            <label>Contraseña *</label>

                            <input
                                class="input"
                                type="password"
                                name="password"
                                required>

                        </div>

                    </div>

                    <% } else { %>

                        <input
                            type="hidden"
                            name="id_rol"
                            value="2">

                        <div class="filters__row">

                            <div class="field">

                                <label>Contraseña *</label>

                                <input
                                    class="input"
                                    type="password"
                                    name="password"
                                    required>

                            </div>

                        </div>

                    <% } %>

                </div>

                <div
                    style="
                        display:flex;
                        justify-content:flex-end;
                        gap:12px;
                        margin-top:30px;
                    ">

                    <a
                        href="/usuarios"
                        class="btn btn-outline">

                        Cancelar

                    </a>

                    <button
                        type="submit"
                        class="btn btn-primary">

                        Guardar Usuario

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>