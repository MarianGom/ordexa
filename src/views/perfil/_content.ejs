<section class="stack-6">
  <div>
    <h1 class="h1">Mi Perfil</h1>
    <p class="sub">Tus datos en el sistema</p>
  </div>

  <% const initials = `${usuario.nombre?.[0] || ''}${usuario.apellido?.[0] || ''}`.toUpperCase(); %>
  <div class="card profile-summary">
    <div class="profile-avatar"><%= initials %></div>
    <div>
      <h2><%= usuario.nombre %> <%= usuario.apellido %></h2>
      <p><%= usuario.correo %></p>
      <span class="role-badge"><%= usuario.rol?.nombre || "Sin rol" %></span>
    </div>
  </div>

  <div class="card profile-details">
    <h2>Información personal</h2>
    <div class="profile-section">
      <h3>Identificación</h3>
      <div class="profile-grid">
        <div><span>CUIL</span><strong><%= usuario.cuil %></strong></div>
        <div><span>Correo electrónico</span><strong class="profile-email"><%= usuario.correo %></strong></div>
      </div>
    </div>
    <div class="profile-section">
      <h3>Datos personales</h3>
      <div class="profile-grid">
        <div><span>Nombre</span><strong><%= usuario.nombre %></strong></div>
        <div><span>Apellido</span><strong><%= usuario.apellido %></strong></div>
      </div>
    </div>
    <div class="profile-section">
      <h3>Contacto</h3>
      <div class="profile-grid">
        <div><span>Teléfono</span><strong><%= usuario.telefono || "—" %></strong></div>
        <div><span>Domicilio</span><strong><%= usuario.domicilio || "—" %></strong></div>
      </div>
    </div>
    <div class="profile-section">
      <h3>Acceso</h3>
      <div class="profile-grid">
        <div><span>Rol</span><strong><%= usuario.rol?.nombre || "Sin rol" %></strong></div>
      </div>
    </div>
  </div>
</section>
